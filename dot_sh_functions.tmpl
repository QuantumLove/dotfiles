#!/bin/sh
# Shared shell functions for both Zsh (Warp) and Bash (Dev Containers)
# Uses POSIX-compliant syntax for maximum compatibility

# Set AWS profile and environment to staging (or custom environment)
# Usage: awstg [environment]
# Example: awstg dev4
awstg() {
    local env="${1:-staging}"
    export AWS_PROFILE=staging
    export ENVIRONMENT="$env"
    echo "✓ Switched to staging profile with ENVIRONMENT=$env"
}

# Set AWS profile and environment to production
awspr() {
    export AWS_PROFILE=production
    export ENVIRONMENT=production
    echo "✓ Switched to production environment"
}

# Jump to the chezmoi source directory (works in bash and zsh)
my-chezmoi() {
    cd "$HOME/.local/share/chezmoi" || return
}

# Load environment variables from a file
# Usage: loadenv .env
loadenv() {
    if [ -z "$1" ]; then
        echo "Usage: loadenv <file>"
        return 1
    fi
    
    if [ ! -f "$1" ]; then
        echo "Error: File '$1' not found"
        return 1
    fi
    
    set -a
    . "$1"
    set +a
    echo "✓ Loaded environment variables from $1"
}

# Reset minikube for the inspect-action project
# Only works when inside the METR/inspect-action repository
minikube_reset() {
    # Check if we're in a git repository
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        echo "Error: Not in a git repository"
        return 1
    fi
    
    # Check if this is the inspect-action repo
    local remote_url=$(git remote get-url origin 2>/dev/null)
    if ! echo "$remote_url" | grep -q "METR/inspect-action"; then
        echo "Error: This command only works in the METR/inspect-action repository"
        echo "Current repository: $remote_url"
        return 1
    fi
    
    # Get the repository root
    local repo_root=$(git rev-parse --show-toplevel)
    
    echo "🔄 Resetting minikube environment..."
    
    # Stop docker compose containers
    if [ -f "$repo_root/docker-compose.yaml" ]; then
        echo "→ Stopping docker compose containers..."
        (cd "$repo_root" && docker compose down)
    fi
    
    # Delete minikube cluster
    echo "→ Deleting minikube cluster..."
    minikube delete
    
    # Start minikube with the project script
    if [ -f "$repo_root/scripts/dev/start-minikube.sh" ]; then
        echo "→ Starting fresh minikube environment..."
        (cd "$repo_root" && ./scripts/dev/start-minikube.sh)
    else
        echo "Warning: start-minikube.sh not found at $repo_root/scripts/dev/"
        return 1
    fi
    
    echo "✅ Minikube reset complete"
}


# tmux session helpers (work socket; override with WARP_TMUX_SOCKET)
# ws [name]  create or attach session <name> (default: main), nesting-safe
ws() {
    local sock="${WARP_TMUX_SOCKET:-work}" name="${1:-main}"
    tmux -L "$sock" has-session -t "$name" 2>/dev/null || tmux -L "$sock" new-session -d -s "$name"
    if [ -n "${TMUX:-}" ]; then
        tmux -L "$sock" switch-client -t "$name" 2>/dev/null || TMUX= tmux -L "$sock" attach -t "$name"
    else
        tmux -L "$sock" attach -t "$name"
    fi
}

# wsl  list sessions on the work socket
wsl() {
    local sock="${WARP_TMUX_SOCKET:-work}"
    tmux -L "$sock" list-sessions 2>/dev/null || echo "no sessions on '$sock'"
}

{{- if eq .chezmoi.os "darwin" }}
# Update Homebrew formulae and casks. Casks with `auto_updates true`
# are skipped by brew on purpose — their apps update themselves.
brew-up() {
    brew update && brew upgrade && brew cleanup
}

# Warp tab helpers (macOS only)
# Uses working URL scheme: warp://action/new_tab?path=

# Open a new Warp tab at the specified (or current) directory
warp-tab() {
    local target_path="${1:-$PWD}"
    open "warp://action/new_tab?path=$target_path"
}

# Open a new Warp window at the specified (or current) directory
warp-window() {
    local target_path="${1:-$PWD}"
    open "warp://action/new_window?path=$target_path"
}

# Open METR development workspace (4 tabs)
metr-dev() {
    echo "Opening METR development workspace..."
    open "warp://action/new_tab?path=$HOME/code/inspect-action"
    sleep 0.3
    open "warp://action/new_tab?path=$HOME/code/mp4-deploy"
    sleep 0.3
    open "warp://action/new_tab?path=$HOME/code/metr-iam"
    sleep 0.3
    open "warp://action/new_tab?path=$HOME/.local/share/chezmoi"
    echo "✓ Opened 4 tabs: inspect-action, mp4-deploy, metr-iam, chezmoi"
}

# Open METR deploy workspace (2 tabs)
metr-deploy() {
    echo "Opening METR deploy workspace..."
    open "warp://action/new_tab?path=$HOME/code/inspect-action"
    sleep 0.3
    open "warp://action/new_tab?path=$HOME/code/mp4-deploy"
    echo "✓ Opened 2 tabs: inspect-action, mp4-deploy"
}
{{- end }}
