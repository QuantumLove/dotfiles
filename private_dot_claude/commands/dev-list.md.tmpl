# Dev List - List All Worktrees

List all git worktrees across all repositories in the code directory.

## Usage

```bash
/dev-list              # List all worktrees
/dev-list --active     # Only show worktrees with uncommitted changes
```

## Implementation

```bash
#!/bin/bash
set -euo pipefail

CODE_DIR="$HOME/code"
ACTIVE_ONLY=false

[[ "${1:-}" == "--active" ]] && ACTIVE_ONLY=true

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🌳 Git Worktrees"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Find all git repos and list their worktrees
find "$CODE_DIR" -maxdepth 3 -name ".git" -type d 2>/dev/null | while read gitdir; do
  repo_path=$(dirname "$gitdir")

  # Skip if it's a worktree (has .git file, not directory)
  [[ -f "$gitdir" ]] && continue

  worktrees=$(git -C "$repo_path" worktree list 2>/dev/null || true)

  if [[ -n "$worktrees" && $(echo "$worktrees" | wc -l) -gt 1 ]]; then
    repo_name=$(basename "$repo_path")
    echo "📁 $repo_name"

    echo "$worktrees" | while read line; do
      path=$(echo "$line" | awk '{print $1}')
      branch=$(echo "$line" | awk '{print $3}' | tr -d '[]')

      # Check for uncommitted changes
      has_changes=""
      if git -C "$path" diff --quiet 2>/dev/null && git -C "$path" diff --cached --quiet 2>/dev/null; then
        has_changes=""
      else
        has_changes=" *"
      fi

      if [[ "$ACTIVE_ONLY" == "true" && -z "$has_changes" ]]; then
        continue
      fi

      printf "   %-50s %s%s\n" "$path" "$branch" "$has_changes"
    done
    echo ""
  fi
done

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "* = uncommitted changes"
```

