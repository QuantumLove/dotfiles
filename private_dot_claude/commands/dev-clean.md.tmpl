# Dev Clean - Clean Up Worktrees

Remove merged or stale git worktrees across all repositories in ~/code.

## Usage

```bash
/dev-clean              # Interactive cleanup
/dev-clean --merged     # Only remove worktrees whose branches are merged
/dev-clean --dry-run    # Show what would be removed
```

## Implementation

```bash
#!/bin/bash
set -euo pipefail

CODE_DIR="$HOME/code"
DRY_RUN=false
MERGED_ONLY=false

for arg in "$@"; do
  case $arg in
    --dry-run) DRY_RUN=true ;;
    --merged) MERGED_ONLY=true ;;
  esac
done

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🧹 Worktree Cleanup"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Find all git repos
find "$CODE_DIR" -maxdepth 3 -name ".git" -type d 2>/dev/null | while read gitdir; do
  repo_path=$(dirname "$gitdir")
  [[ -f "$gitdir" ]] && continue

  repo_name=$(basename "$repo_path")

  # Get worktrees (skip main worktree)
  git -C "$repo_path" worktree list 2>/dev/null | tail -n +2 | while read line; do
    wt_path=$(echo "$line" | awk '{print $1}')
    branch=$(echo "$line" | awk '{print $3}' | tr -d '[]')

    # Skip if path doesn't exist
    [[ ! -d "$wt_path" ]] && continue

    # Check if branch is merged to main/master
    is_merged=false
    default_branch=$(git -C "$repo_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
    if git -C "$repo_path" branch --merged "$default_branch" 2>/dev/null | grep -q "$branch"; then
      is_merged=true
    fi

    # Check for uncommitted changes
    has_changes=false
    if ! git -C "$wt_path" diff --quiet 2>/dev/null || ! git -C "$wt_path" diff --cached --quiet 2>/dev/null; then
      has_changes=true
    fi

    # Decide whether to show/remove
    if [[ "$MERGED_ONLY" == "true" && "$is_merged" != "true" ]]; then
      continue
    fi

    status=""
    [[ "$is_merged" == "true" ]] && status="[merged] "
    [[ "$has_changes" == "true" ]] && status="${status}[uncommitted] "

    echo "📁 $repo_name: $wt_path"
    echo "   Branch: $branch $status"

    if [[ "$has_changes" == "true" ]]; then
      echo "   ⚠️  Has uncommitted changes - skipping"
      echo ""
      continue
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
      echo "   Would remove: git worktree remove $wt_path"
    else
      read -p "   Remove this worktree? (yes/no): " confirm
      if [[ "$confirm" == "yes" ]]; then
        git -C "$repo_path" worktree remove "$wt_path"
        echo "   ✅ Removed"
      else
        echo "   Skipped"
      fi
    fi
    echo ""
  done
done

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Done!"
```

## Safety

- Never removes worktrees with uncommitted changes
- Always confirms before removing (unless --dry-run)
- Use --merged to only clean up branches already merged to main
