# .bash_profile for login shells

# Source .bashrc for interactive login shells
[ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc"

# Load shared custom functions
[ -f "$HOME/.sh_functions" ] && . "$HOME/.sh_functions"

# mise - tool version manager (for containers/SSH)
if [ -d "$HOME/.local/share/mise" ]; then
  export PATH="$HOME/.local/share/mise/shims:$PATH"
  eval "$(mise activate bash 2>/dev/null)"
fi

# Container-specific setup (only runs inside Docker containers)
if [ -f /.dockerenv ]; then
  # Load secrets injected by container entrypoint
  [ -f "$HOME/.secrets_env" ] && . "$HOME/.secrets_env"

  # SSH Agent for git operations (host agent mounted at /ssh-agent)
  [ -S "/ssh-agent" ] && export SSH_AUTH_SOCK=/ssh-agent

  # Default working directory for mega-container SSH sessions
  [ -d "$HOME/code/platform" ] && cd "$HOME/code/platform"
fi
