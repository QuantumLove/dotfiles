# Minimal .zshrc for Warp
# Warp handles themes, completions, and most shell features
# This file only loads our custom shell functions

# Add ~/bin to PATH
export PATH="$HOME/bin:$PATH"

# Load shared custom functions for Warp
[ -f "$HOME/.sh_functions" ] && . "$HOME/.sh_functions"

# Load bash-compatible functions (oc utilities, etc.) — zsh supports bash-isms
[ -f "$HOME/.bash_functions" ] && . "$HOME/.bash_functions"

# 1Password Configuration
# Option 1: Service Account Token (Recommended - no interactive login)
# Get token from: https://my.1password.com → Integrations → Service Accounts

# Method A: macOS Keychain (most secure)
if [ -z "$OP_SERVICE_ACCOUNT_TOKEN" ] && command -v security &> /dev/null; then
    export OP_SERVICE_ACCOUNT_TOKEN=$(security find-generic-password -a "$USER" -s "OP_SERVICE_ACCOUNT_TOKEN" -w 2>/dev/null)
fi

# Method B: Secure file
if [ -z "$OP_SERVICE_ACCOUNT_TOKEN" ] && [ -f ~/.config/op/service-account-token ]; then
    export OP_SERVICE_ACCOUNT_TOKEN=$(cat ~/.config/op/service-account-token)
fi

# Load MCP/API credentials from 1Password, cached in the macOS Keychain. A new
# shell then costs ~3 fast keychain reads instead of ~3 × 0.8s `op read` network
# round-trips. Cache entry format is "<epoch>:<secret>"; we re-fetch from
# 1Password only past the TTL, in the background, so a warm shell never blocks.
OP_SECRET_TTL=43200  # re-fetch keys older than 12h

_op_refresh_secret() {  # $1 = keychain service, $2 = op:// reference
    command -v op &>/dev/null && command -v security &>/dev/null || return
    [ -n "$OP_SERVICE_ACCOUNT_TOKEN" ] || return
    local v; v="$(op read "$2" 2>/dev/null)" || return
    [ -n "$v" ] && security add-generic-password -U -a "$USER" -s "$1" -w "$(date +%s):${v}" 2>/dev/null
}

_op_load_secret() {  # $1 = env var, $2 = keychain service, $3 = op:// reference
    local var="$1" svc="$2" ref="$3" blob ts val now
    now="$(date +%s)"

    # No keychain (e.g. Linux): direct, uncached read.
    if ! command -v security &>/dev/null; then
        command -v op &>/dev/null && [ -n "$OP_SERVICE_ACCOUNT_TOKEN" ] || return
        val="$(op read "$ref" 2>/dev/null)"; [ -n "$val" ] && export "$var=$val"
        return
    fi

    blob="$(security find-generic-password -a "$USER" -s "$svc" -w 2>/dev/null)"
    ts="${blob%%:*}"; val="${blob#*:}"
    case "$ts" in ''|*[!0-9]*) ts=0; val="";; esac

    if [ -n "$val" ]; then
        export "$var=$val"
        if [ $(( now - ts )) -ge "$OP_SECRET_TTL" ]; then
            _op_refresh_secret "$svc" "$ref" &!   # stale: refresh in background
        fi
        return
    fi

    # Cold cache: fetch once synchronously, then export.
    _op_refresh_secret "$svc" "$ref"
    blob="$(security find-generic-password -a "$USER" -s "$svc" -w 2>/dev/null)"
    val="${blob#*:}"; [ -n "$val" ] && export "$var=$val"
}

# Force a re-fetch on the next shell (run after rotating a key in 1Password).
refresh-op-secrets() {
    local s
    for s in OP_CACHE_LINEAR_API_KEY OP_CACHE_OPENAI_API_KEY OP_CACHE_GEMINI_API_KEY; do
        security delete-generic-password -a "$USER" -s "$s" &>/dev/null
    done
    echo "1Password key cache cleared — next shell will re-fetch."
}

if command -v op &>/dev/null || command -v security &>/dev/null; then
    if [ -n "$OP_SERVICE_ACCOUNT_TOKEN" ] || command -v security &>/dev/null; then
        [ -z "$LINEAR_API_KEY" ] && _op_load_secret LINEAR_API_KEY OP_CACHE_LINEAR_API_KEY "op://Development/Linear MCP API Key/credential"
        [ -n "$LINEAR_API_KEY" ] && export AUTHORIZATION="Bearer $LINEAR_API_KEY"
        [ -z "$OPENAI_API_KEY" ] && _op_load_secret OPENAI_API_KEY OP_CACHE_OPENAI_API_KEY "op://Development/OpenAI API Key/credential"
        [ -z "$GEMINI_API_KEY" ] && _op_load_secret GEMINI_API_KEY OP_CACHE_GEMINI_API_KEY "op://Development/Google Gemini API Key/credential"

        # gh CLI uses keyring auth; GitHub MCP uses OAuth — no GITHUB_TOKEN needed.
    else
        echo "💡 1Password: No service account token found. You may be prompted to sign in."
        echo "   To enable automatic auth, see: ~/.local/share/chezmoi/1PASSWORD_SETUP.md"
    fi
fi
