#!/bin/bash
# =============================================================================
# Claude Code Plugin Bootstrap (chezmoi run_once script)
# =============================================================================
#
# First-time setup: registers marketplaces and installs plugins.
# Runs once per machine. Subsequent plugin installs are handled by
# run_onchange_install-plugins.sh when plugin-list.txt changes.
#
# Marketplaces are NOT managed as chezmoi files because they contain
# platform-specific absolute paths. Each platform registers its own
# via `claude plugin marketplace add` which generates correct paths.
# =============================================================================
set -e

if ! command -v claude &> /dev/null; then
    echo "Claude Code not installed, skipping plugin setup"
    exit 0
fi

echo "🔌 Setting up Claude Code plugins..."
echo ""

# Register plugin marketplaces (idempotent — no-ops if already registered)
echo "📦 Registering plugin marketplaces..."

register_marketplace() {
  local repo="$1"
  echo "   Registering $repo..."
  if ! claude plugin marketplace add "$repo"; then
    echo "   ⚠️  Failed to register $repo"
  fi
}

register_marketplace "anthropics/claude-plugins-official"
register_marketplace "EveryInc/compound-engineering-plugin"
register_marketplace "obra/superpowers-marketplace"
register_marketplace "METR/claude-code"

# Install all plugins from plugin-list.txt
echo ""
echo "📥 Installing plugins..."

while IFS= read -r plugin || [ -n "$plugin" ]; do
    [[ -z "$plugin" || "$plugin" =~ ^# ]] && continue

    echo "   Installing: $plugin"
    if ! claude plugin install "$plugin"; then
      echo "   ⚠️  Failed to install $plugin (may already be installed or marketplace unavailable)"
    fi
done < "{{ .chezmoi.sourceDir }}/private_dot_claude/plugin-list.txt"

echo ""
echo "🎉 Claude Code plugins ready!"
echo "   Restart Claude Code to use new plugins."
