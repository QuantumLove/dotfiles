#!/usr/bin/env bash
# proof-local — run the self-hosted Proof editor (on the container; reach it from the
# host with `proof-local tunnel`, which forwards :3000+:4000 so localhost is the same Proof).
#
# Everything stays on this machine: docs live in ~/code/proof-sdk/proof-share.db
# (local SQLite), telemetry is hard-off, nothing is published to proofeditor.ai
# or any external service. Does NOT start automatically — you spin it up when you
# want it and stop it when done.
#
#   proof-local start              # start API (:4000) + editor (:3000) — run where proof-sdk lives (the container)
#   proof-local open <file.md> [t] # publish a local markdown file, print+open editor URL
#   proof-local tunnel             # (host) forward :3000+:4000 to the container's Proof so localhost works
#   proof-local ensure             # start only if down (idempotent; run by supercronic on the container)
#   proof-local stop               # stop both servers
#   proof-local status             # show what's running
set -euo pipefail

PROOF_DIR="${PROOF_SDK_DIR:-$HOME/code/proof-sdk}"
API="http://127.0.0.1:4000"
EDITOR_BASE="http://127.0.0.1:3000"
STATE_DIR="$HOME/.local/state/proof-local"
mkdir -p "$STATE_DIR"

_api_up() { curl -fsS "$API/health" >/dev/null 2>&1; }
_editor_up() { curl -fsS "$EDITOR_BASE/" >/dev/null 2>&1; }

start() {
  [ -d "$PROOF_DIR" ] || { echo "proof-sdk not found at $PROOF_DIR (set PROOF_SDK_DIR)" >&2; exit 1; }
  if _api_up; then
    echo "API already up on :4000"
  else
    # HOST=127.0.0.1 keeps the API on loopback. proof-sdk's server.listen() binds
    # all interfaces by default, which would expose local docs on shared WiFi.
    ( cd "$PROOF_DIR" && HOST=127.0.0.1 PORT=4000 COLLAB_EMBEDDED_WS=1 VITE_ENABLE_TELEMETRY=false nohup npm run serve >"$STATE_DIR/server.log" 2>&1 & echo $! >"$STATE_DIR/server.pid" )
    echo "starting API (:4000)…"
  fi
  if _editor_up; then
    echo "editor already up on :3000"
  else
    # --host 127.0.0.1 pins vite to IPv4 loopback (it defaults to [::1]); keeps it
    # consistent with the API and reachable through `proof-local tunnel` (-L …:127.0.0.1).
    ( cd "$PROOF_DIR" && VITE_ENABLE_TELEMETRY=false nohup npm run dev -- --host 127.0.0.1 >"$STATE_DIR/editor.log" 2>&1 & echo $! >"$STATE_DIR/editor.pid" )
    echo "starting editor (:3000)…"
  fi
  for _ in $(seq 1 40); do _api_up && break; sleep 0.5; done
  if _api_up; then
    echo "Proof is up — API $API · editor $EDITOR_BASE"
  else
    echo "API did not come up; see $STATE_DIR/server.log" >&2; exit 1
  fi
}

open_doc() {
  local file="${1:?usage: proof-local open <markdown-file> [title]}"
  [ -f "$file" ] || { echo "no such file: $file" >&2; exit 1; }
  local title="${2:-$(basename "$file")}"
  _api_up || start
  local resp slug token url
  resp=$(jq -Rs --arg t "$title" '{title:$t, markdown:.}' "$file" \
    | curl -fsS -X POST "$API/documents" -H "Content-Type: application/json" -d @-)
  slug=$(printf '%s' "$resp" | jq -r '.slug')
  token=$(printf '%s' "$resp" | jq -r '.accessToken')
  [ -n "$slug" ] && [ "$slug" != "null" ] || { echo "create failed: $resp" >&2; exit 1; }
  url="$EDITOR_BASE/d/$slug?token=$token"
  echo "$url"
  command -v open >/dev/null 2>&1 && open "$url" >/dev/null 2>&1 || true
}

stop() {
  local pids pf
  for pf in "$STATE_DIR"/server.pid "$STATE_DIR"/editor.pid; do
    [ -f "$pf" ] && kill "$(cat "$pf")" 2>/dev/null || true
  done
  for port in 4000 3000; do
    pids=$(lsof -ti tcp:"$port" 2>/dev/null || true)
    [ -n "$pids" ] && kill $pids 2>/dev/null || true
  done
  # lsof is blind inside the container; pkill the node procs by their proof-sdk path.
  pkill -f "$PROOF_DIR/node_modules" 2>/dev/null || true
  rm -f "$STATE_DIR"/*.pid
  echo "Proof stopped (freed :4000 and :3000)."
}

status() {
  _api_up && echo "API    :4000  UP" || echo "API    :4000  down"
  _editor_up && echo "editor :3000  UP" || echo "editor :3000  down"
}

# (host) forward the container's Proof ports so localhost:3000/:4000 reach it.
# Proof stays loopback-bound on the container; the SSH hop is tailnet-authenticated.
tunnel() {
  local host="${PROOF_TUNNEL_HOST:-raf-dev}"
  echo "Proof tunnel → $host : localhost:3000 (editor) + :4000 (API). Ctrl+C to stop."
  exec ssh -N -L 3000:127.0.0.1:3000 -L 4000:127.0.0.1:4000 "$host"
}

# Idempotent watchdog target (run by supercronic): start Proof only if it isn't up.
ensure() {
  _api_up && _editor_up && return 0
  start >/dev/null 2>&1
}

case "${1:-start}" in
  start|up)   start ;;
  open)       shift; open_doc "$@" ;;
  tunnel)     tunnel ;;
  ensure)     ensure ;;
  stop|down)  stop ;;
  status)     status ;;
  *) echo "usage: proof-local {start|open <file.md> [title]|tunnel|ensure|stop|status}" >&2; exit 1 ;;
esac
